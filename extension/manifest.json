{
  "manifest_version": 3,
  "name": "Zivo",
  "version": "0.3.0",
  "description": "한일 노선 항공권 편도 조합 최저가 & 원터치 예약",
  "key": "",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Zivo"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://api.zivo.app/*",
    "https://zivo-production.up.railway.app/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.koreanair.com/*",
        "https://*.flyasiana.com/*",
        "https://*.jal.co.jp/*",
        "https://*.ana.co.jp/*",
        "https://*.jejuair.net/*",
        "https://*.jinair.com/*",
        "https://*.airbusan.com/*",
        "https://*.twayair.com/*",
        "https://*.flypeach.com/*",
        "https://*.jetstar.com/*"
      ],
      "js": ["src/content/autofill.ts"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "src/assets/icon-16.png",
    "48": "src/assets/icon-48.png",
    "128": "src/assets/icon-128.png"
  }
}
