# Database
DATABASE_URL=postgresql+asyncpg://zivo:zivo@localhost:5432/zivo
REDIS_URL=redis://localhost:6379/0

# Flight APIs
DUFFEL_API_KEY=duffel_test_replace_me
# Phase 2 이후
KIWI_API_KEY=
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# Auth / Security
JWT_SECRET_KEY=change_me_to_long_random_string
# 32바이트 base64 (openssl rand -base64 32)
AES_ENCRYPTION_KEY=change_me_base64_32_bytes

# Kakao (Phase 2)
KAKAO_CLIENT_ID=
KAKAO_REDIRECT_URI=http://localhost:8000/auth/kakao/callback
KAKAO_ALIMTALK_API_KEY=

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_app_password_here   # Gmail 앱 비밀번호 (16자리)
SMTP_FROM=Zivo <your_gmail@gmail.com>

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
# 프로덕션: chrome-extension://*,https://zivo.app,https://www.zivo.app
CORS_ORIGINS=chrome-extension://*,http://localhost:3000
